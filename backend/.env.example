# ===== DeepSeek API 配置 =====
# 申请地址：https://platform.deepseek.com/
# 获取后填入下方（不要提交到 Git）
DEEPSEEK_API_KEY=sk-your-api-key-here

# 模型选择
# - deepseek-chat：通用对话模型，性价比高
# - deepseek-reasoner：推理增强模型，适合复杂合同审核（更贵更慢）
DEEPSEEK_MODEL=deepseek-chat

# API 基础地址（DeepSeek 兼容 OpenAI 协议）
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ===== 服务配置 =====
# 后端端口
BACKEND_PORT=8000

# CORS 允许的前端地址（Vite 默认 5173/5174）
FRONTEND_ORIGIN=http://localhost:5173,http://localhost:5174

# AI 调用超时（秒）
AI_TIMEOUT=120

# 是否启用 Mock 模式（API Key 未配置时自动启用，返回 Mock 数据）
# true：使用 Mock；false：强制真实调用
MOCK_MODE=auto
